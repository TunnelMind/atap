{
  "name": "@tunnelmindai/atap",
  "version": "0.1.0",
  "description": "Reference TypeScript wrapper for ATAP v0.1 — Agent Trust Attestation Protocol. Witness service helpers, hash-chain construction, receipt assembly, in-process verification.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "atap",
    "attestation",
    "agent",
    "compliance",
    "ed25519",
    "sha256",
    "audit",
    "receipt",
    "transparency",
    "tunnelmind"
  ],
  "author": "TunnelMind",
  "license": "MIT",
  "homepage": "https://tunnelmind.ai/atap/standard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TunnelMind/atap.git",
    "directory": "packages/atap-js"
  },
  "bugs": {
    "url": "https://github.com/TunnelMind/atap/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^5.6.0"
  }
}
